<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_color">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center">

        <!-- Avatar inisial -->
        <TextView
            android:id="@+id/tvAvatar"
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:gravity="center"
            android:textSize="36sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:background="@drawable/bg_avatar"
            android:layout_marginBottom="16dp"/>

        <!-- Nama + ikon pensil -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="4dp">

            <TextView
                android:id="@+id/tvProfileName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nama Pengguna"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"/>

            <ImageButton
                android:id="@+id/btnEditName"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_edit"
                android:background="@android:color/transparent"
                android:layout_marginStart="8dp"
                android:contentDescription="Edit nama"/>

        </LinearLayout>

        <!-- Email -->
        <TextView
            android:id="@+id/tvProfileEmail"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="email@example.com"
            android:textSize="14sp"
            android:textColor="@color/text_muted"
            android:layout_marginBottom="16dp"/>

        <!-- Form edit nama (tersembunyi by default) -->
        <LinearLayout
            android:id="@+id/layoutEditName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:layout_marginBottom="16dp">

            <EditText
                android:id="@+id/etEditName"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:hint="Nama baru"
                android:inputType="textPersonName"
                android:background="@color/white"
                android:padding="10dp"
                android:layout_marginBottom="8dp"/>

            <Button
                android:id="@+id/btnSaveName"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="SIMPAN PERUBAHAN"
                android:backgroundTint="@color/brand_secondary"
                android:textColor="@color/white"/>

        </LinearLayout>

        <!-- Ringkasan pesanan -->
        <com.google.android.material.card.MaterialCardView
            xmlns:app="http://schemas.android.com/apk/res-auto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ringkasan Pesanan"
                    android:textSize="14sp"
                    android:textColor="@color/text_muted"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:id="@+id/tvTotalItems"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 item dipesan"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/brand_primary"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Riwayat pesanan -->
        <com.google.android.material.card.MaterialCardView
            xmlns:app="http://schemas.android.com/apk/res-auto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Riwayat Pesanan"
                    android:textSize="14sp"
                    android:textColor="@color/text_muted"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:id="@+id/tvEmptyHistory"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Belum ada pesanan"
                    android:textSize="13sp"
                    android:textColor="@color/text_muted"
                    android:visibility="gone"/>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvOrderHistory"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Logout -->
        <Button
            android:id="@+id/btnLogout"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="KELUAR"
            android:backgroundTint="@color/brand_primary"
            android:textColor="@color/white"/>

    </LinearLayout>
</ScrollView>